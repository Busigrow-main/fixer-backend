# ──────────────────────────────────────────────
# Fixxer Backend — Environment Variables Example
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

NODE_ENV=development
PORT=3000

MONGO_URI=mongodb://localhost:27017/fixxer

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:3001

# Technician onboarding: set false in production to enforce pincode whitelist
ALLOW_ALL_PINCODES=true

ELASTICSEARCH_NODE=http://localhost:9200

# Cloudinary (AC appliance images — never commit real secrets)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=fixxer/appliances
